# wowctl configuration file
# Location: ~/Library/Application Support/wowctl/config.toml (macOS)
#           %APPDATA%\wowctl\config.toml (Windows)

# Path to your World of Warcraft addon directory
# If not set, wowctl will attempt to auto-detect it
# addon_dir = "/Applications/World of Warcraft/_retail_/Interface/AddOns"

# Your CurseForge API key
# Get one at: https://console.curseforge.com/
# You can also set this via the WOWCTL_CURSEFORGE_API_KEY environment variable
# curseforge_api_key = "your-api-key-here"

# Enable or disable colored output
# You can also disable colors with --no-color flag or NO_COLOR environment variable
color = true
